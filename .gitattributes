# Force LF line endings for shell scripts so they work on Linux/macOS
*.sh    text eol=lf

# Force LF for Python scripts as well (cross-platform)
*.py    text eol=lf

# Windows scripts stay CRLF on checkout
*.ps1   text eol=crlf

# Markdown and text files: normalise to LF
*.md    text eol=lf
*.txt   text eol=lf
*.conf  text eol=lf
